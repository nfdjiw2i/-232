local Library = {}
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")

local GUI = Instance.new("ScreenGui")
GUI.Name = "CodeBHackLibrary"
GUI.Parent = CoreGui
GUI.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
GUI.ResetOnSpawn = false
GUI.DisplayOrder = 100

local MainFrame = nil
local ColumnsFrame = nil
local TabButtons = {}
local CurrentColor = Color3.fromRGB(0, 255, 0) -- Ярко-зеленый для пиксельного стиля
local IsVisible = true
local HideButton = nil

local Tabs = {}

-- Функция для создания пиксельной рамки
local function createPixelBorder(parent, size, position, color)
    local border = Instance.new("Frame")
    border.Size = size
    border.Position = position
    border.BackgroundColor3 = color or Color3.fromRGB(0, 255, 0)
    border.BorderSizePixel = 0
    border.Parent = parent
    return border
end

function Library:CreateLib(title, theme)
    MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 600, 0, 700) -- Увеличил размер
    MainFrame.Position = UDim2.new(0.5, -300, 0.5, -350)
    MainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Чисто черный фон
    MainFrame.BorderSizePixel = 0 -- Убираем стандартные границы
    MainFrame.Parent = GUI
    MainFrame.Active = true
    
    -- Пиксельные рамки вокруг основного окна
    createPixelBorder(MainFrame, UDim2.new(1, 2, 0, 2), UDim2.new(0, -2, 0, 0)) -- Левая
    createPixelBorder(MainFrame, UDim2.new(1, 2, 0, 2), UDim2.new(1, 0, 0, 0)) -- Правая
    createPixelBorder(MainFrame, UDim2.new(0, 2, 1, 2), UDim2.new(0, -2, 0, -2)) -- Верхняя
    createPixelBorder(MainFrame, UDim2.new(0, 2, 1, 2), UDim2.new(1, 0, 0, -2)) -- Верхняя правая
    createPixelBorder(MainFrame, UDim2.new(0, 2, 1, 2), UDim2.new(0, -2, 1, 0)) -- Нижняя
    createPixelBorder(MainFrame, UDim2.new(0, 2, 1, 2), UDim2.new(1, 0, 1, 0)) -- Нижняя правая
    
    -- Title Bar (пиксельный стиль)
    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.Size = UDim2.new(1, -4, 0, 40)
    titleBar.Position = UDim2.new(0, 2, 0, 2)
    titleBar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    titleBar.BorderSizePixel = 2
    titleBar.BorderColor3 = CurrentColor
    titleBar.Parent = MainFrame
    
    HideButton = Instance.new("TextButton")
    HideButton.Name = "HideButton"
    HideButton.Size = UDim2.new(0, 30, 0, 30)
    HideButton.Position = UDim2.new(0, 5, 0, 5)
    HideButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    HideButton.BorderSizePixel = 2
    HideButton.BorderColor3 = CurrentColor
    HideButton.Text = "<"
    HideButton.TextColor3 = CurrentColor
    HideButton.TextSize = 16
    HideButton.Font = Enum.Font.Code
    HideButton.Parent = titleBar
    
    local titleText = Instance.new("TextLabel")
    titleText.Name = "TitleText"
    titleText.Size = UDim2.new(1, -105, 1, 0)
    titleText.Position = UDim2.new(0, 40, 0, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = "> " .. (title or "CODE B HACK MODULE") .. " <"
    titleText.TextColor3 = CurrentColor
    titleText.TextSize = 16
    titleText.Font = Enum.Font.Code
    titleText.TextXAlignment = Enum.TextXAlignment.Left
    titleText.Parent = titleBar
    
    local closeBtn = Instance.new("TextButton")
    closeBtn.Name = "CloseButton"
    closeBtn.Size = UDim2.new(0, 40, 0, 30)
    closeBtn.Position = UDim2.new(1, -45, 0, 5)
    closeBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    closeBtn.BorderSizePixel = 2
    closeBtn.BorderColor3 = CurrentColor
    closeBtn.Text = "X"
    closeBtn.TextColor3 = CurrentColor
    closeBtn.TextSize = 16
    closeBtn.Font = Enum.Font.Code
    closeBtn.Parent = titleBar
    closeBtn.MouseButton1Click:Connect(function() GUI:Destroy() end)
    
    local ResizeButton = Instance.new("TextButton")
    ResizeButton.Name = "ResizeButton"
    ResizeButton.Size = UDim2.new(0, 20, 0, 20)
    ResizeButton.Position = UDim2.new(1, -25, 1, -25)
    ResizeButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    ResizeButton.BorderSizePixel = 2
    ResizeButton.BorderColor3 = CurrentColor
    ResizeButton.Text = ">"
    ResizeButton.TextColor3 = CurrentColor
    ResizeButton.TextSize = 14
    ResizeButton.Font = Enum.Font.Code
    ResizeButton.TextRotation = 45
    ResizeButton.Parent = MainFrame
    
    ColumnsFrame = Instance.new("Frame")
    ColumnsFrame.Name = "ColumnsFrame"
    ColumnsFrame.Size = UDim2.new(1, -24, 1, -150) -- Уменьшил высоту для панели статистики
    ColumnsFrame.Position = UDim2.new(0, 12, 0, 50)
    ColumnsFrame.BackgroundTransparency = 1
    ColumnsFrame.Parent = MainFrame
    
    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.Size = UDim2.new(1, -24, 0, 40)
    tabBar.Position = UDim2.new(0, 12, 0, 5)
    tabBar.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    tabBar.BorderSizePixel = 2
    tabBar.BorderColor3 = CurrentColor
    tabBar.Parent = MainFrame
    tabBar.ClipsDescendants = true
    
    local tabContainer = Instance.new("Frame")
    tabContainer.Name = "TabContainer"
    tabContainer.Size = UDim2.new(1, -10, 1, -6)
    tabContainer.Position = UDim2.new(0, 5, 0, 3)
    tabContainer.BackgroundTransparency = 1
    tabContainer.Parent = tabBar
    
    -- Панель статистики (новая)
    local statsPanel = Instance.new("Frame")
    statsPanel.Name = "StatsPanel"
    statsPanel.Size = UDim2.new(1, -24, 0, 60)
    statsPanel.Position = UDim2.new(0, 12, 1, -70)
    statsPanel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    statsPanel.BorderSizePixel = 2
    statsPanel.BorderColor3 = CurrentColor
    statsPanel.Parent = MainFrame
    
    -- Разделители для статистики
    local statLabels = {}
    local statNames = {"FPS", "PING", "MEMORY", "PLAYERS", "UPTIME"}
    local statValues = {}
    
    for i, name in ipairs(statNames) do
        local xPos = (i-1) * 0.2
        
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(0.2, -4, 0.3, 0)
        nameLabel.Position = UDim2.new(xPos, 2, 0, 2)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = name .. ":"
        nameLabel.TextColor3 = Color3.fromRGB(100, 100, 100)
        nameLabel.TextSize = 11
        nameLabel.Font = Enum.Font.Code
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = statsPanel
        
        local valueLabel = Instance.new("TextLabel")
        valueLabel.Size = UDim2.new(0.2, -4, 0.5, 0)
        valueLabel.Position = UDim2.new(xPos, 2, 0.3, 0)
        valueLabel.BackgroundTransparency = 1
        valueLabel.Text = "0"
        valueLabel.TextColor3 = CurrentColor
        valueLabel.TextSize = 14
        valueLabel.Font = Enum.Font.Code
        valueLabel.TextXAlignment = Enum.TextXAlignment.Left
        valueLabel.Parent = statsPanel
        
        statValues[name] = valueLabel
        
        if i < 5 then
            local divider = Instance.new("Frame")
            divider.Size = UDim2.new(0, 2, 0.8, 0)
            divider.Position = UDim2.new(xPos + 0.2, 0, 0.1, 0)
            divider.BackgroundColor3 = CurrentColor
            divider.BorderSizePixel = 0
            divider.Parent = statsPanel
        end
    end
    
    -- Обновление статистики
    local startTime = tick()
    local lastFpsUpdate = 0
    local frameCount = 0
    
    RunService.RenderStepped:Connect(function()
        frameCount = frameCount + 1
        local currentTime = tick()
        
        if currentTime - lastFpsUpdate >= 0.5 then
            local fps = math.floor(frameCount / (currentTime - lastFpsUpdate))
            local ping = math.floor(Stats:FindFirstChild("Network"):FindFirstChild("ServerStatsItem"):GetValue() * 1000)
            local memory = math.floor(collectgarbage("count") / 1024)
            local players = #game:GetService("Players"):GetPlayers()
            local uptime = math.floor(currentTime - startTime)
            local hours = math.floor(uptime / 3600)
            local minutes = math.floor((uptime % 3600) / 60)
            local seconds = uptime % 60
            
            statValues["FPS"].Text = tostring(fps)
            statValues["PING"].Text = tostring(ping) .. "ms"
            statValues["MEMORY"].Text = tostring(memory) .. "MB"
            statValues["PLAYERS"].Text = tostring(players)
            statValues["UPTIME"].Text = string.format("%02d:%02d:%02d", hours, minutes, seconds)
            
            lastFpsUpdate = currentTime
            frameCount = 0
        end
    end)
    
    -- Dragging
    local dragging = false
    local dragStart, startPos
    
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    -- Resizing
    local resizing = false
    local resizeStart, startSize
    
    ResizeButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            resizeStart = input.Position
            startSize = MainFrame.Size
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - resizeStart
            local newWidth = math.max(400, startSize.X.Offset + delta.X)
            local newHeight = math.max(500, startSize.Y.Offset + delta.Y)
            MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = false
        end
    end)
    
    -- Hide/show functionality
    HideButton.MouseButton1Click:Connect(function()
        IsVisible = not IsVisible
        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Linear)
        
        if IsVisible then
            HideButton.Text = "<"
            local goal = {Size = UDim2.new(0, 600, 0, 700)}
            TweenService:Create(MainFrame, tweenInfo, goal):Play()
            ColumnsFrame.Visible = true
            tabBar.Visible = true
            statsPanel.Visible = true
            ResizeButton.Visible = true
        else
            HideButton.Text = ">"
            local goal = {Size = UDim2.new(0, 200, 0, 40)}
            TweenService:Create(MainFrame, tweenInfo, goal):Play()
            ColumnsFrame.Visible = false
            tabBar.Visible = false
            statsPanel.Visible = false
            ResizeButton.Visible = false
        end
    end)
    
    -- Hotkey
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == Enum.KeyCode.RightControl then
            IsVisible = not IsVisible
            local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Linear)
            
            if IsVisible then
                HideButton.Text = "<"
                TweenService:Create(MainFrame, tweenInfo, {Size = UDim2.new(0, 600, 0, 700)}):Play()
                ColumnsFrame.Visible = true
                tabBar.Visible = true
                statsPanel.Visible = true
                ResizeButton.Visible = true
            else
                HideButton.Text = ">"
                TweenService:Create(MainFrame, tweenInfo, {Size = UDim2.new(0, 200, 0, 40)}):Play()
                ColumnsFrame.Visible = false
                tabBar.Visible = false
                statsPanel.Visible = false
                ResizeButton.Visible = false
            end
        end
    end)
    
    -- Функция обновления размеров табов
    local function updateTabSizes()
        local containerWidth = tabContainer.AbsoluteSize.X
        local tabCount = #TabButtons
        if tabCount == 0 then return end
        
        local tabWidth = math.floor((containerWidth - 10 * (tabCount - 1)) / tabCount)
        tabWidth = math.clamp(tabWidth, 80, 150)
        
        for i, tabBtn in ipairs(TabButtons) do
            tabBtn.Size = UDim2.new(0, tabWidth, 1, -6)
            tabBtn.Position = UDim2.new(0, (i - 1) * (tabWidth + 10) + 5, 0, 3)
        end
    end
    
    tabBar:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)
    
    return self
end

-- ===== КЛАСС TAB =====
function Library:NewTab(name)
    -- Создаем контейнер для вкладок если его нет
    local tabContainer = ColumnsFrame:FindFirstChild("TabContainer")
    if not tabContainer then
        tabContainer = Instance.new("Frame")
        tabContainer.Name = "TabContainer"
        tabContainer.Size = UDim2.new(1, 0, 1, 0)
        tabContainer.BackgroundTransparency = 1
        tabContainer.Parent = ColumnsFrame
    end
    
    -- Создаем фрейм для этой вкладки
    local tabFrame = Instance.new("ScrollingFrame")
    tabFrame.Name = "Tab_" .. name
    tabFrame.Size = UDim2.new(1, 0, 1, 0)
    tabFrame.Position = UDim2.new(0, 0, 0, 0)
    tabFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    tabFrame.BorderSizePixel = 2
    tabFrame.BorderColor3 = CurrentColor
    tabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabFrame.ScrollBarThickness = 8
    tabFrame.ScrollBarImageColor3 = CurrentColor
    tabFrame.Parent = tabContainer
    tabFrame.Visible = false
    
    -- Контейнер для элементов внутри вкладки
    local container = Instance.new("Frame")
    container.Name = "Container"
    container.Size = UDim2.new(1, -20, 1, -20)
    container.Position = UDim2.new(0, 10, 0, 10)
    container.BackgroundTransparency = 1
    container.Parent = tabFrame
    
    -- Создаем кнопку вкладки
    local tabBar = MainFrame:FindFirstChild("TabBar")
    local tabButtonContainer = tabBar and tabBar:FindFirstChild("TabContainer")
    
    if tabButtonContainer then
        local tabButton = Instance.new("TextButton")
        tabButton.Name = "TabButton_" .. name
        tabButton.Size = UDim2.new(0, 100, 1, -6)
        tabButton.Position = UDim2.new(0, (#TabButtons * 110 + 5), 0, 3)
        tabButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        tabButton.BorderSizePixel = 2
        tabButton.BorderColor3 = CurrentColor
        tabButton.Text = "> " .. name .. " <"
        tabButton.TextColor3 = (#TabButtons == 0) and CurrentColor or Color3.fromRGB(100, 100, 100)
        tabButton.TextSize = 12
        tabButton.Font = Enum.Font.Code
        tabButton.Parent = tabButtonContainer
        
        table.insert(TabButtons, tabButton)
        
        -- Если это первая вкладка, показываем её
        if #TabButtons == 1 then
            tabFrame.Visible = true
        end
        
        -- Обработчик клика по вкладке
        tabButton.MouseButton1Click:Connect(function()
            -- Скрываем все вкладки
            for _, child in pairs(tabContainer:GetChildren()) do
                if child:IsA("ScrollingFrame") then
                    child.Visible = false
                end
            end
            
            -- Показываем выбранную вкладку
            tabFrame.Visible = true
            
            -- Обновляем цвета кнопок
            for _, btn in ipairs(TabButtons) do
                btn.TextColor3 = Color3.fromRGB(100, 100, 100)
                btn.BorderColor3 = CurrentColor
            end
            
            tabButton.TextColor3 = CurrentColor
            tabButton.BorderColor3 = CurrentColor
        end)
        
        -- Обновляем размеры кнопок
        local function updateTabSizes()
            local containerWidth = tabButtonContainer.AbsoluteSize.X
            local tabCount = #TabButtons
            if tabCount == 0 then return end
            
            local tabWidth = math.floor((containerWidth - 10 * (tabCount - 1)) / tabCount)
            tabWidth = math.clamp(tabWidth, 80, 150)
            
            for i, btn in ipairs(TabButtons) do
                btn.Size = UDim2.new(0, tabWidth, 1, -6)
                btn.Position = UDim2.new(0, (i - 1) * (tabWidth + 10) + 5, 0, 3)
            end
        end
        
        tabButtonContainer:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)
        updateTabSizes()
    end
    
    -- ===== ВОЗВРАЩАЕМ ОБЪЕКТ TAB =====
    local TabObject = {}
    local yPositions = {}
    
    function TabObject:NewSection(sectionName)
        local currentY = 0
        for _, child in pairs(container:GetChildren()) do
            if child:IsA("TextLabel") and child.Text:find("//") then
                currentY = currentY + 40
            end
        end
        
        -- Заголовок секции
        local sectionTitle = Instance.new("TextLabel")
        sectionTitle.Size = UDim2.new(1, 0, 0, 30)
        sectionTitle.Position = UDim2.new(0, 0, 0, currentY)
        sectionTitle.BackgroundTransparency = 1
        sectionTitle.Text = "// " .. sectionName .. " //"
        sectionTitle.TextColor3 = CurrentColor
        sectionTitle.TextSize = 14
        sectionTitle.Font = Enum.Font.Code
        sectionTitle.TextXAlignment = Enum.TextXAlignment.Left
        sectionTitle.Parent = container
        
        -- Пиксельная линия под заголовком
        local sectionLine = Instance.new("Frame")
        sectionLine.Size = UDim2.new(1, 0, 0, 2)
        sectionLine.Position = UDim2.new(0, 0, 0, currentY + 25)
        sectionLine.BackgroundColor3 = CurrentColor
        sectionLine.BorderSizePixel = 0
        sectionLine.Parent = container
        
        -- Счетчик элементов внутри этой секции
        local elementY = currentY + 40
        
        -- Функция обновления позиций всех элементов после определенного индекса
        local function updatePositionsAfter(startY)
            -- Эта функция будет обновлять CanvasSize фрейма
            tabFrame.CanvasSize = UDim2.new(0, 0, 0, elementY + 10)
        end
        
        -- ===== ВОЗВРАЩАЕМ ОБЪЕКТ SECTION =====
        local SectionObject = {}
        
        function SectionObject:NewButton(buttonName, description, callback)
            local buttonFrame = Instance.new("Frame")
            buttonFrame.Size = UDim2.new(1, 0, 0, 60)
            buttonFrame.Position = UDim2.new(0, 0, 0, elementY)
            buttonFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            buttonFrame.BorderSizePixel = 2
            buttonFrame.BorderColor3 = Color3.fromRGB(50, 50, 50)
            buttonFrame.Parent = container
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -20, 0, 25)
            nameLabel.Position = UDim2.new(0, 10, 0, 5)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = "> " .. buttonName
            nameLabel.TextColor3 = CurrentColor
            nameLabel.TextSize = 14
            nameLabel.Font = Enum.Font.Code
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = buttonFrame
            
            local descLabel = Instance.new("TextLabel")
            descLabel.Size = UDim2.new(1, -20, 0, 20)
            descLabel.Position = UDim2.new(0, 10, 0, 30)
            descLabel.BackgroundTransparency = 1
            descLabel.Text = description or ""
            descLabel.TextColor3 = Color3.fromRGB(100, 100, 100)
            descLabel.TextSize = 10
            descLabel.Font = Enum.Font.Code
            descLabel.TextXAlignment = Enum.TextXAlignment.Left
            descLabel.Parent = buttonFrame
            
            local button = Instance.new("TextButton")
            button.Size = UDim2.new(1, 0, 1, 0)
            button.BackgroundTransparency = 1
            button.Text = ""
            button.Parent = buttonFrame
            
            button.MouseEnter:Connect(function()
                buttonFrame.BorderColor3 = CurrentColor
            end)
            
            button.MouseLeave:Connect(function()
                buttonFrame.BorderColor3 = Color3.fromRGB(50, 50, 50)
            end)
            
            button.MouseButton1Click:Connect(function()
                buttonFrame.BorderColor3 = CurrentColor
                task.wait(0.1)
                buttonFrame.BorderColor3 = Color3.fromRGB(50, 50, 50)
                
                if callback then
                    local success, err = pcall(callback)
                    if not success then
                        warn("Error in button callback: " .. err)
                    end
                end
            end)
            
            elementY = elementY + 70
            updatePositionsAfter(elementY)
            
            return SectionObject
        end
        
        function SectionObject:NewToggle(toggleName, description, callback)
            local toggleFrame = Instance.new("Frame")
            toggleFrame.Size = UDim2.new(1, 0, 0, 50)
            toggleFrame.Position = UDim2.new(0, 0, 0, elementY)
            toggleFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            toggleFrame.BorderSizePixel = 2
            toggleFrame.BorderColor3 = Color3.fromRGB(50, 50, 50)
            toggleFrame.Parent = container
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -80, 0, 25)
            nameLabel.Position = UDim2.new(0, 10, 0, 5)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = "> " .. toggleName
            nameLabel.TextColor3 = CurrentColor
            nameLabel.TextSize = 14
            nameLabel.Font = Enum.Font.Code
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = toggleFrame
            
            local descLabel = Instance.new("TextLabel")
            descLabel.Size = UDim2.new(1, -80, 0, 20)
            descLabel.Position = UDim2.new(0, 10, 0, 25)
            descLabel.BackgroundTransparency = 1
            descLabel.Text = description or ""
            descLabel.TextColor3 = Color3.fromRGB(100, 100, 100)
            descLabel.TextSize = 10
            descLabel.Font = Enum.Font.Code
            descLabel.TextXAlignment = Enum.TextXAlignment.Left
            descLabel.Parent = toggleFrame
            
            local toggleBg = Instance.new("Frame")
            toggleBg.Size = UDim2.new(0, 50, 0, 24)
            toggleBg.Position = UDim2.new(1, -60, 0.5, -12)
            toggleBg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            toggleBg.BorderSizePixel = 2
            toggleBg.BorderColor3 = CurrentColor
            toggleBg.Parent = toggleFrame
            
            local toggleIndicator = Instance.new("Frame")
            toggleIndicator.Size = UDim2.new(0, 20, 0, 16)
            toggleIndicator.Position = UDim2.new(0, 2, 0.5, -8)
            toggleIndicator.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            toggleIndicator.BorderSizePixel = 1
            toggleIndicator.BorderColor3 = CurrentColor
            toggleIndicator.Parent = toggleBg
            
            local toggleState = false
            
            local function updateToggle()
                if toggleState then
                    toggleIndicator.BackgroundColor3 = CurrentColor
                    toggleIndicator.Position = UDim2.new(1, -22, 0.5, -8)
                else
                    toggleIndicator.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                    toggleIndicator.Position = UDim2.new(0, 2, 0.5, -8)
                end
            end
            
            local toggleButton = Instance.new("TextButton")
            toggleButton.Size = UDim2.new(1, 0, 1, 0)
            toggleButton.BackgroundTransparency = 1
            toggleButton.Text = ""
            toggleButton.Parent = toggleFrame
            
            toggleButton.MouseButton1Click:Connect(function()
                toggleState = not toggleState
                updateToggle()
                
                if callback then
                    local success, err = pcall(function() callback(toggleState) end)
                    if not success then warn("Error in toggle callback: " .. err) end
                end
            end)
            
            elementY = elementY + 60
            updatePositionsAfter(elementY)
            
            return SectionObject
        end
        
        function SectionObject:NewSlider(sliderName, description, min, max, default, callback)
            local sliderFrame = Instance.new("Frame")
