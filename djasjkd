                sliderButton.Parent = sliderBg

                local currentValue = default or min
                local dragging = false

                local function setSliderValue(value)
                    currentValue = math.clamp(math.floor(value), min, max)
                    local percent = (currentValue - min) / (max - min)
                    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
                    sliderDot.Position = UDim2.new(percent, -7, 0.5, -7)
                    valueBox.Text = tostring(currentValue)
                    SliderValues[sliderId] = currentValue
                    if callback then
                        local success, err = pcall(function()
                            callback(currentValue)
                        end)
                        if not success then
                        end
                    end
                end

                local function updateSlider(input)
                    local mousePos = input.Position
                    local absPos = sliderBg.AbsolutePosition
                    local absSize = sliderBg.AbsoluteSize.X
                    local relativeX = math.clamp(mousePos.X - absPos.X, 0, absSize)
                    local percent = relativeX / absSize
                    local value = min + (max - min) * percent
                    setSliderValue(value)
                end

                if default then
                    setSliderValue(default)
                end

                sliderButton.MouseButton1Down:Connect(function(input)
                    dragging = true
                    updateSlider(input)
                end)

                valueBox.FocusLost:Connect(function(enterPressed)
                    local val = tonumber(valueBox.Text)
                    if val then
                        setSliderValue(val)
                    else
                        valueBox.Text = tostring(currentValue)
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateSlider(input)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)

                function SectionObject:GetSliderValue()
                    return currentValue
                end

                function SectionObject:SetSliderValue(value)
                    setSliderValue(value)
                end

                tabData.YPosition = currentY + 80
                tabData.Frame.CanvasSize = UDim2.new(0, 0, 0, tabData.YPosition + 10)
                return sliderFrame
            end

