    end

    function Library:GetToggleState(id)
        return ToggleStates[id] or false
    end

    function Library:GetSliderValue(id)
        return SliderValues[id] or 0
    end

    function Library:GetInputToggleState(id)
        return InputToggleStates[id] or {state = false, text = ""}
    end

    function Library:SetToggleState(id, value)
        ToggleStates[id] = value
    end

    function Library:SetSliderValue(id, value)
        SliderValues[id] = value
    end

    function Library:Destroy()
        isScannerTheme = false
        clearHackerLabels()
        destroyAllDetachedWindows()
        screenGui:Destroy()
    end

    function Library:Hide()
        isHidden = true
        savedPos = Vector2.new(mainFrame.AbsolutePosition.X, mainFrame.AbsolutePosition.Y)
        savedSize = Vector2.new(mainFrame.AbsoluteSize.X, mainFrame.AbsoluteSize.Y)
        mainFrame.Visible = false
        mainFrame.Position = UDim2.new(0, -9999, 0, -9999)
        hideAllDetachedWindows()
    end

    function Library:Show()
        isHidden = false
        mainFrame.Visible = true
        mainFrame.Size = UDim2.new(0, savedSize.X, 0, savedSize.Y)
        mainFrame.Position = UDim2.new(0, math.clamp(savedPos.X, 0, workspace.CurrentCamera.ViewportSize.X - savedSize.X), 0, math.clamp(savedPos.Y, 0, workspace.CurrentCamera.ViewportSize.Y - savedSize.Y))
        showAllDetachedWindows()
    end

    return Library
end

if not KeyVerified then
    showKeyUI()
else
    return InitializeLibrary()
end

return Library
