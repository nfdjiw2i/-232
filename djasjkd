    local function clearHackerLabels()
        for _, label in ipairs(hackerLabels) do
            if label and label.Parent then
                label:Destroy()
            end
        end
        hackerLabels = {}
    end

    local function spawnHackerText()
        if not isScannerTheme then return end
        if not screenGui or not screenGui.Parent then return end
        
        local text = HackerCommands[math.random(1, #HackerCommands)]
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 0, 14)
        label.Position = UDim2.new(0, math.random(-100, 0), math.random(5, 85) / 100, 0)
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextColor3 = CurrentColor
        label.TextTransparency = 0.6
        label.TextSize = 10
        label.Font = Enum.Font.Code
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.ZIndex = 1
        label.Parent = hackerBg
        
        table.insert(hackerLabels, label)
        
        task.spawn(function()
            local startTime = tick()
            while label and label.Parent and tick() - startTime < 5 do
                if not isScannerTheme then break end
                local elapsed = tick() - startTime
                if elapsed > 4 then
                    label.TextTransparency = 0.6 + (elapsed - 4) * 0.4
                end
                task.wait(0.1)
            end
            if label and label.Parent then
                label:Destroy()
            end
            for i, v in ipairs(hackerLabels) do
                if v == label then
                    table.remove(hackerLabels, i)
                    break
                end
            end
        end)
    end

    local function applyScannerTheme()
        isScannerTheme = true
        scanLine.Visible = true
        scanLine.BackgroundTransparency = 0.7
        mainStroke.Thickness = 2
        
        clearHackerLabels()
        
        task.spawn(function()
            while isScannerTheme and screenGui and screenGui.Parent do
                spawnHackerText()
                task.wait(math.random(3, 6))
            end
        end)
        
        task.spawn(function()
            while isScannerTheme and screenGui and screenGui.Parent do
                for i = 0, 1, 0.005 do
                    if not isScannerTheme then break end
                    scanLine.Position = UDim2.new(0, 0, i, 0)
                    task.wait(0.01)
                end
                for i = 1, 0, -0.005 do
                    if not isScannerTheme then break end
                    scanLine.Position = UDim2.new(0, 0, i, 0)
                    task.wait(0.01)
                end
            end
        end)
    end

    local function removeScannerTheme()
        isScannerTheme = false
        scanLine.Visible = false
        scanLine.BackgroundTransparency = 1
        mainStroke.Thickness = 1.5
        clearHackerLabels()
    end

