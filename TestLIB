    local startPos

    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    local resizing = false
    local resizeStart
    local startSize

    ResizeButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            resizeStart = input.Position
            startSize = MainFrame.Size
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - resizeStart
            local newWidth = math.max(300, startSize.X.Offset + delta.X)
            local newHeight = math.max(400, startSize.Y.Offset + delta.Y)
            MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
            ColumnsFrame.Size = UDim2.new(1, -20, 1, -105)
            for _, section in pairs(Sections) do
                if section.Frame then
                    section.Frame.Size = UDim2.new(1, 0, 1, 0)
                end
            end
            if UIElements.updateTabSizes then
                UIElements.updateTabSizes()
            end
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = false
        end
    end)

    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.Size = UDim2.new(1, -20, 0, 35)
    tabBar.Position = UDim2.new(0, 10, 0, 5)
    tabBar.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    tabBar.BorderSizePixel = 1
    tabBar.BorderColor3 = Color3.fromRGB(50, 50, 50)
    tabBar.Parent = MainFrame
    tabBar.ClipsDescendants = true

    local tabContainer = Instance.new("Frame")
    tabContainer.Name = "TabContainer"
    tabContainer.Size = UDim2.new(1, -10, 1, 0)
    tabContainer.Position = UDim2.new(0, 5, 0, 0)
    tabContainer.BackgroundTransparency = 1
    tabContainer.Parent = tabBar
    tabContainer.ClipsDescendants = false

    UIElements.TabBar = tabBar
    UIElements.TabContainer = tabContainer

    local function updateTabSizes()
        local containerWidth = tabContainer.AbsoluteSize.X
        local tabCount = #TabButtons
        if tabCount == 0 then return end
        local minTabWidth = 70
        local maxTabWidth = 120
        local availableWidth = containerWidth - 5 * (tabCount - 1)
        local tabWidth = math.floor(availableWidth / tabCount)
        tabWidth = math.clamp(tabWidth, minTabWidth, maxTabWidth)
        if tabWidth < minTabWidth then
            tabWidth = minTabWidth
        end
        for i, tabBtn in ipairs(TabButtons) do
            tabBtn.Size = UDim2.new(0, tabWidth, 1, -2)
            tabBtn.Position = UDim2.new(0, (i - 1) * (tabWidth + 5) + 5, 0, 1)
            if #tabBtn.Text > 8 then
                tabBtn.TextSize = 12
            else
                tabBtn.TextSize = 14
            end
        end
    end

    tabBar:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateTabSizes)
    UIElements.updateTabSizes = updateTabSizes

    local function toggleMenu()
        IsVisible = not IsVisible
        local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        if IsVisible then
            HideButton.Text = "◀"
            local goal = {Size = UDim2.new(0, 500, 0, 600), BackgroundTransparency = 0}
            local tween = TweenService:Create(MainFrame, tweenInfo, goal)
            tween:Play()
            ColumnsFrame.Visible = true
            UIElements.TabBar.Visible = true
            bottomFrame.Visible = true
            ResizeButton.Visible = true
        else
            HideButton.Text = "▶"
            local goal = {Size = UDim2.new(0, 200, 0, 40), BackgroundTransparency = 0}
            local tween = TweenService:Create(MainFrame, tweenInfo, goal)
            tween:Play()
            ColumnsFrame.Visible = false
            UIElements.TabBar.Visible = false
            bottomFrame.Visible = false
            ResizeButton.Visible = false
        end
    end

    HideButton.MouseButton1Click:Connect(toggleMenu)

    HideButton.MouseEnter:Connect(function()
        HideButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end)

    HideButton.MouseLeave:Connect(function()
        HideButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    end)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            toggleMenu()
        end
    end)

    return self
end

function Library:NewTab(name)
    TabCounter = TabCounter + 1
    local tabContainer = UIElements.TabContainer
    local tabCount = #TabButtons

    local tabButton = Instance.new("TextButton")
    tabButton.Name = "Tab_" .. name .. "_" .. TabCounter
    tabButton.Size = UDim2.new(0, 100, 1, -2)
    tabButton.Position = UDim2.new(0, tabCount * 105 + 5, 0, 1)
    tabButton.BackgroundTransparency = 1
    tabButton.Text = name
    tabButton.TextColor3 = (tabCount == 0) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 140)
    tabButton.TextSize = 14
    tabButton.Font = Enum.Font.Code
    tabButton.BorderSizePixel = 0
    tabButton.Parent = tabContainer

    table.insert(TabButtons, tabButton)

    local section = Instance.new("ScrollingFrame")
    section.Name = name .. "Section_" .. TabCounter
    section.Size = UDim2.new(1, 0, 1, 0)
    section.Position = UDim2.new(0, 0, 0, 0)
    section.BackgroundTransparency = 1
    section.BorderSizePixel = 0
    section.CanvasSize = UDim2.new(0, 0, 0, 0)
    section.ScrollBarThickness = 8
    section.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 80)
    section.Parent = ColumnsFrame
    section.Visible = (tabCount == 0)

    local container = Instance.new("Frame")
    container.Name = "Container_" .. TabCounter
    container.Size = UDim2.new(1, -20, 1, -20)
    container.Position = UDim2.new(0, 10, 0, 10)
    container.BackgroundTransparency = 1
    container.Parent = section

    local tabData = {
        Frame = section,
        Container = container,
        YPosition = 0,
        Button = tabButton,
        Name = name,
        Index = TabCounter
    }

    local tabKey = name .. "_" .. TabCounter
    Sections[tabKey] = tabData
    Tabs[tabKey] = tabData

    if tabCount == 0 then
        CurrentTab = tabKey
        local line = Instance.new("Frame")
        line.Size = UDim2.new(1, 0, 0, 2)
        line.Position = UDim2.new(0, 0, 1, -2)
        line.BackgroundColor3 = CurrentColor
        line.BorderSizePixel = 0
        line.Parent = tabButton
        UIElements.ActiveLine = line
    end

    tabButton.MouseButton1Click:Connect(function()
        CurrentTab = tabKey
        for _, btn in ipairs(TabButtons) do
            btn.TextColor3 = Color3.fromRGB(140, 140, 140)
        end
        tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        if UIElements.ActiveLine then
            UIElements.ActiveLine:Destroy()
        end
        local line = Instance.new("Frame")
        line.Size = UDim2.new(1, 0, 0, 2)
        line.Position = UDim2.new(0, 0, 1, -2)
        line.BackgroundColor3 = CurrentColor
        line.BorderSizePixel = 0
        line.Parent = tabButton
        UIElements.ActiveLine = line
        for _, tab in pairs(Sections) do
            tab.Frame.Visible = false
        end
        tabData.Frame.Visible = true
    end)

    if UIElements.updateTabSizes then
        UIElements.updateTabSizes()
    end

    local TabObject = {}

    function TabObject:NewSection(sectionName)
        local SectionObject = {}
        local container = tabData.Container
        local yPos = tabData.YPosition

        local sectionTitle = Instance.new("TextLabel")
        sectionTitle.Size = UDim2.new(1, 0, 0, 30)
        sectionTitle.Position = UDim2.new(0, 0, 0, yPos)
        sectionTitle.BackgroundTransparency = 1
        sectionTitle.Text = "// " .. sectionName
        sectionTitle.TextColor3 = Color3.fromRGB(230, 230, 230)
        sectionTitle.TextSize = 16
        sectionTitle.Font = Enum.Font.Code
        sectionTitle.TextXAlignment = Enum.TextXAlignment.Left
        sectionTitle.Parent = container

        local sectionLine = Instance.new("Frame")
        sectionLine.Size = UDim2.new(1, 0, 0, 2)
        sectionLine.Position = UDim2.new(0, 0, 0, yPos + 25)
        sectionLine.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        sectionLine.BorderSizePixel = 0
        sectionLine.Parent = container

        tabData.YPosition = yPos + 40

        local function updateAllPositions()
            local startY = 40
            for _, child in ipairs(container:GetChildren()) do
                if child:IsA("Frame") and child ~= sectionTitle and child ~= sectionLine then
                    child.Position = UDim2.new(0, 0, 0, startY)
                    startY = startY + child.Size.Y.Offset + 10
                end
            end
            tabData.YPosition = startY
            tabData.Frame.CanvasSize = UDim2.new(0, 0, 0, startY + 10)
        end

        function SectionObject:NewButton(buttonName, description, callback)
            local currentY = tabData.YPosition

            local buttonFrame = Instance.new("Frame")
